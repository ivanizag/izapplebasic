"9592":"horizontal index",
"9594":"...always",
"9596":"put bit 6 into sign position",
"9601":"carry is set",
"9603":"E = E - deltaY",
"9605":"note: DY is (-delta Y)-1",
"9607":"carry clr if HGR_E goes negative",
